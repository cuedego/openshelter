# Global project defaults (single source of truth)
AWS_REGION=eu-central-1
# Keep account- and state-specific values out of versioned files.
# Set them in config/local.env or export them in your shell.
AWS_ACCOUNT_ID=
ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
ECR_REGISTRY_ALIAS=openshelter
TF_STATE_BUCKET=
TF_LOCK_TABLE=
TF_STATE_KEY_PREFIX=openshelter
GITHUB_ORG=cuedego
GITHUB_REPO=openshelter
ARGOCD_CHART_VERSION=7.3.4
ESO_CHART_VERSION=0.10.3
