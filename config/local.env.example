# Local, non-versioned overrides.
# Copy to config/local.env and customize for your machine/profile.

# AWS account ID used to compose ECR_REGISTRY in Makefile.
# You can populate automatically with:
# AWS_ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text)
AWS_ACCOUNT_ID=REPLACE_WITH_12_DIGIT_ACCOUNT_ID

# Terraform remote state resources used only for local workflows.
TF_STATE_BUCKET=REPLACE_WITH_TERRAFORM_STATE_BUCKET
TF_LOCK_TABLE=REPLACE_WITH_TERRAFORM_LOCK_TABLE

# Optional override if you do not want the versioned default.
# TF_STATE_KEY_PREFIX=openshelter
